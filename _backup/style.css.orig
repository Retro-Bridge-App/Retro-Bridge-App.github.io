:root {
  --bg: #f7f5f6;
  --surface: #ffffff;
  --surface-soft: #fbfafb;
  --ink: #161416;
  --muted: #6f6870;
  --quiet: #9a9299;
  --line: rgba(22, 20, 22, 0.1);
  --line-strong: rgba(22, 20, 22, 0.18);
  --accent: #E5169B;
  --accent-soft: rgba(229, 22, 155, 0.1);
  --shadow: 0 24px 60px rgba(22, 20, 22, 0.12);
  --max: 1060px;
}

* {
  box-sizing: border-box;
}

html,
body {
  height: 100%;
}

body {
  margin: 0;
  min-height: 100dvh;
  height: 100dvh;
  overflow: hidden;
  color: var(--ink);
  background:
    radial-gradient(circle at 50% 0%, var(--accent-soft), transparent 34rem),
    linear-gradient(180deg, #ffffff 0%, var(--bg) 58%, #f4f1f3 100%);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  display: grid;
  grid-template-rows: auto 1fr auto;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  max-width: 100%;
}

h1,
p {
  margin: 0;
}

.topbar {
  width: min(var(--max), calc(100% - 48px));
  margin: 0 auto;
  padding: 18px 0 10px;
  display: flex;
  align-items: center;
  gap: 22px;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  color: var(--ink);
  font-size: 16px;
  font-weight: 750;
  letter-spacing: 0;
  white-space: nowrap;
}

.brand img {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  box-shadow: 0 0 0 1px var(--line);
}

.nav {
  display: flex;
  align-items: center;
  gap: 24px;
  color: var(--muted);
  font-size: 14px;
  font-weight: 560;
}

.nav a {
  transition: color 160ms ease;
}

.nav a:hover {
  color: var(--accent);
}

.spacer {
  flex: 1;
}

.ghost,
.primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  border-radius: 8px;
  font-weight: 760;
  transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
}

.ghost {
  padding: 0 17px;
  border: 1px solid var(--line-strong);
  background: rgba(255, 255, 255, 0.72);
  color: var(--ink);
  font-size: 14px;
  white-space: nowrap;
}

.ghost:hover {
  border-color: rgba(229, 22, 155, 0.42);
  transform: translateY(-1px);
}

.stage {
  width: min(var(--max), calc(100% - 48px));
  margin: 0 auto;
  padding: 20px 0 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
}

h1 {
  max-width: 12ch;
  font-size: 64px;
  line-height: 1.02;
  font-weight: 820;
  letter-spacing: 0;
}

.value {
  max-width: 55ch;
  margin-top: 18px;
  color: var(--muted);
  font-size: 19px;
  line-height: 1.6;
}

.value strong {
  color: var(--ink);
  font-weight: 780;
}

.app-card {
  width: min(580px, 100%);
  margin-top: 34px;
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: var(--shadow);
}

.route {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 48px minmax(0, 1fr);
  gap: 12px;
  align-items: center;
}

.leg {
  min-width: 0;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--surface-soft);
  text-align: left;
}

.label {
  display: block;
  color: var(--quiet);
  font-size: 12px;
  font-weight: 780;
  letter-spacing: 0;
  text-transform: uppercase;
}

.chip {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 9px;
  color: var(--ink);
  font-size: 20px;
  font-weight: 820;
  letter-spacing: 0;
  white-space: nowrap;
}

.chip img {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  flex: 0 0 auto;
}

.switch {
  width: 48px;
  height: 48px;
  padding: 0;
  border: 1px solid var(--line-strong);
  border-radius: 50%;
  background: var(--surface);
  color: var(--muted);
  cursor: pointer;
  display: grid;
  place-items: center;
  box-shadow: 0 10px 24px rgba(22, 20, 22, 0.08);
  transition: transform 180ms ease, color 160ms ease, border-color 160ms ease;
}

.switch span {
  display: block;
  font-size: 22px;
  line-height: 1;
}

.switch:hover {
  color: var(--accent);
  border-color: rgba(229, 22, 155, 0.42);
}

.switch.is-switched {
  transform: rotate(180deg);
}

.primary {
  width: 100%;
  margin-top: 14px;
  padding: 0 22px;
  background: var(--accent);
  color: #ffffff;
  font-size: 17px;
  box-shadow: 0 16px 34px rgba(229, 22, 155, 0.24);
}

.primary:hover {
  background: var(--accent);
  transform: translateY(-1px);
}

.footer {
  padding: 10px 24px 20px;
  color: var(--quiet);
  font-size: 13px;
  font-weight: 580;
  text-align: center;
}

@media (max-width: 720px) {
  .topbar {
    width: calc(100% - 32px);
    padding-top: 14px;
    gap: 12px;
  }

  .brand {
    font-size: 15px;
  }

  .nav {
    display: none;
  }

  .stage {
    width: calc(100% - 32px);
    padding-top: 10px;
  }

  h1 {
    font-size: 44px;
  }

  .value {
    margin-top: 14px;
    font-size: 16px;
    line-height: 1.55;
  }

  .app-card {
    margin-top: 26px;
    padding: 14px;
  }

  .route {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .switch {
    justify-self: center;
    width: 44px;
    height: 44px;
  }

  .switch span {
    transform: rotate(90deg);
  }

  .switch.is-switched {
    transform: rotate(180deg);
  }

  .footer {
    padding-bottom: 14px;
  }
}

@media (max-width: 390px) {
  .topbar {
    width: calc(100% - 28px);
  }

  .ghost {
    min-height: 40px;
    padding: 0 12px;
  }

  .stage {
    width: calc(100% - 28px);
  }

  h1 {
    font-size: 40px;
  }

  .app-card {
    margin-top: 20px;
  }

  .leg {
    padding: 12px;
  }
}
